# Copy to .env and fill in values. Never commit .env to version control.

# NewsAPI (newsapi.org)
NEWSAPI_KEY=

# GNews (gnews.io)
GNEWS_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Microsoft Outlook (OAuth2 — configure in n8n credential store)
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# OUTLOOK_TENANT_ID=

# LinkedIn (OAuth2 — configure in n8n credential store)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
